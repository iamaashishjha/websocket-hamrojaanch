# HamroJaanch WebSocket Signaling Server

# Port to listen on.
SIGNALING_PORT=3001

# Environment
NODE_ENV=development

# Required secret for HMAC-SHA256 token signing.
# Never use weak/shared defaults in deployed environments.
SIGNALING_SECRET=change_me_strong_random_secret

# Structured log metadata
SIGNALING_SERVICE_NAME=backend-api
SIGNALING_SERVICE_VERSION=v1
SIGNALING_LOG_SCOPE=signaling

# Token time-to-live in seconds.
SIGNALING_TOKEN_TTL=600

# Comma-separated allowed origins for HTTP/WS endpoints.
SIGNALING_CORS_ORIGIN=http://localhost:8081

# Trust x-forwarded-for only when behind a trusted reverse proxy.
SIGNALING_TRUST_PROXY=false

# Keep false in production; backend should issue signaling tokens.
ALLOW_DIRECT_TOKEN_ENDPOINT=false

# Graceful shutdown timeout in milliseconds.
SHUTDOWN_GRACE_MS=15000

# WebSocket heartbeat interval.
WS_HEARTBEAT_INTERVAL_MS=30000

# Max incoming WS message size.
WS_MAX_MESSAGE_BYTES=65536

# Max JSON size for individual signaling payload fields (SDP/candidate/reason etc).
WS_MAX_SIGNAL_FIELD_BYTES=16384

# Abuse protection limits.
WS_MAX_CONNECTIONS_PER_IP=40
WS_MAX_VIEWERS_PER_ROOM=60
WS_MAX_ROOMS=5000
WS_JOIN_RATE_WINDOW_MS=60000
WS_MAX_JOIN_ATTEMPTS_PER_WINDOW=30
WS_MESSAGE_RATE_WINDOW_MS=10000
WS_MAX_MESSAGES_PER_WINDOW=200
